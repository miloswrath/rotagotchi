{
  "manifest_version": 3,
  "name": "Rotagotchi Dev Extension",
  "version": "0.1.0",
  "description": "Basic development scaffold for the Rotagotchi Chrome extension.",
  "action": {
    "default_title": "Rotagotchi",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
