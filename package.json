{
  "name": "rotagotchi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:extension": "node scripts/build-extension.js",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test --project=e2e",
    "test:e2e:nix": "LIBGBM_PATH=\"$(nix eval --raw nixpkgs#libgbm.outPath)/lib\" && LD_LIBRARY_PATH=\"$LIBGBM_PATH:$LD_LIBRARY_PATH\" playwright test --project=e2e",
    "test:smoke": "playwright test --project=smoke",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "lottie-react": "^2.4.1",
    "lottie-web": "^5.13.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "smee": "^0.2.0",
    "supabase": "^2.78.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.1.38",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.27.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.0.0"
  }
}
